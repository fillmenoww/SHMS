---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { getPerformerImages, nameFromId } from '../../lib/performerImages';
// One page is generated per .md file at build time.
export async function getStaticPaths() {
  const performers = await getCollection('performers');
  return performers.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { city, role, phone, tiktok, facebook, instagram, x, description, tags, featured, keywords } = entry.data;
const name = entry.data.name ?? nameFromId(entry.id);
const images = getPerformerImages(entry.id);
// Render any text written below the frontmatter (optional bio).
const { Content } = await render(entry);

const socials = [
  { key: 'instagram', url: instagram, label: 'Instagram' },
  { key: 'tiktok', url: tiktok, label: 'TikTok' },
  { key: 'facebook', url: facebook, label: 'Facebook' },
  { key: 'x', url: x, label: 'X' },
].filter((s) => s.url);

const autoKeywords = [name, city, role, ...tags].filter(Boolean);
const pageKeywords = [...new Set([...autoKeywords, ...keywords])];
const altFor = (i: number) => `${name} — ${role}, ${city} — photo ${i + 1}`;
---
<Base
  title={`${name} — ${city}`}
  description={`${name}, ${role}. Available in ${city}.`}
  keywords={pageKeywords}
>
  <div class="wrap detail">
    <a class="back" href="/">&larr; All performers</a>

    <div class="detail-grid">
      <!-- Gallery -->
      <div class="d-gallery">
        <div class="d-main">
          {images.map((img, i) => (
          <Image
              src={img}
              alt={altFor(i)}
              width={900}
              height={1125}
              class={i === 0 ? 'd-shot is-active' : 'd-shot'}
              data-index={i}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
        {images.length > 1 && (
          <div class="d-thumbs">
            {images.map((img, i) => (
              <button class={i === 0 ? 'd-thumb is-active' : 'd-thumb'} data-target={i} type="button" aria-label={`View photo ${i + 1}`}>
                <Image src={img} alt="" width={120} height={120} />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="d-info">
     {featured && <span class="featured-badge featured-badge--inline">★ Featured</span>}
        <span class="d-city">{city}</span>
        <h1 class="d-name">{name}</h1>
        <p class="d-role">{role}</p>
        {tags.length > 0 && (
          <ul class="tags d-tags">
            {tags.map((t) => <li class="tag">{t}</li>)}
          </ul>
        )}
        {description && <p class="d-desc">{description}</p>}

        <button class="reveal-btn d-reveal" type="button" data-phone={phone}>
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M6.6 10.8a15.5 15.5 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.57 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.46.57 3.6a1 1 0 0 1-.25 1l-2.2 2.2Z"/></svg>
          <span class="reveal-label">Show number</span>
        </button>

        {socials.length > 0 && (
          <div class="d-socials">
            {socials.map((s) => (
              <a href={s.url} target="_blank" rel="noopener noreferrer" class="d-soc" aria-label={s.label}>{s.label}</a>
            ))}
          </div>
        )}

        <div class="d-body"><Content /></div>

        <!-- Adsterra slot on the profile page -->
        <div class="ad-slot" id="ad-profile"></div>
      </div>
    </div>
  </div>
</Base>

<style>
  .detail { padding: 26px 20px 70px; }
  .back {
    display: inline-block; margin-bottom: 22px;
    font-weight: 600; font-size: 0.92rem; text-decoration: none; color: var(--rose);
  }
  .back:hover { text-decoration: underline; }

  .detail-grid { display: grid; grid-template-columns: 1.05fr 1fr; gap: 34px; align-items: start; }
  @media (max-width: 760px) { .detail-grid { grid-template-columns: 1fr; gap: 22px; } }

  .d-main {
    position: relative; aspect-ratio: 4 / 5;
    border-radius: var(--radius); overflow: hidden;
    background: var(--paper-2); box-shadow: var(--shadow);
  }
  .d-shot { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0; transition: opacity 0.25s ease; }
  .d-shot.is-active { opacity: 1; }

  .d-thumbs { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
  .d-thumb {
    width: 64px; height: 64px; padding: 0; border-radius: 12px; overflow: hidden;
    border: 2px solid transparent; cursor: pointer; background: none; transition: border-color 0.12s ease;
  }
  .d-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .d-thumb.is-active { border-color: var(--rose); }
  .d-thumb:focus-visible { outline: 3px solid var(--gold); outline-offset: 2px; }

  .d-info { padding-top: 4px; }
  .d-city {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--leaf);
  }
  .d-name { font-size: clamp(2rem, 5vw, 3rem); color: var(--ink); margin: 6px 0 10px; }
  .d-role { font-size: 1.15rem; color: var(--ink-soft); margin: 0 0 22px; }
.d-tags { margin: 0 0 16px; }
  .d-desc { margin: 0 0 22px; font-size: 1.04rem; line-height: 1.6; color: var(--ink); max-width: 46ch; }
  .d-reveal { font-size: 1rem; padding: 12px 22px; }

  .d-socials { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
  .d-soc {
    font-weight: 600; font-size: 0.9rem; text-decoration: none;
    padding: 8px 16px; border-radius: 999px;
    background: var(--paper-2); color: var(--ink); transition: background 0.12s ease, color 0.12s ease, transform 0.12s ease;
  }
  .d-soc:hover { background: var(--rose); color: #fff; transform: translateY(-1px); }

  .d-body { margin-top: 24px; color: var(--ink); line-height: 1.65; }
  .d-body:empty { display: none; }
</style>

<script>
  // Phone reveal
  document.querySelectorAll<HTMLButtonElement>('.reveal-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('is-revealed')) return;
      const phone = btn.dataset.phone ?? '';
      const label = btn.querySelector('.reveal-label');
      if (label) label.textContent = phone;
      btn.classList.add('is-revealed');
      btn.addEventListener('click', () => { window.location.href = `tel:${phone.replace(/\s+/g, '')}`; });
    });
  });

  // Gallery swap
  const shots = document.querySelectorAll<HTMLElement>('.d-shot');
  const thumbs = document.querySelectorAll<HTMLButtonElement>('.d-thumb');
  thumbs.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const target = Number(thumb.dataset.target);
      shots.forEach((s, i) => s.classList.toggle('is-active', i === target));
      thumbs.forEach((t, i) => t.classList.toggle('is-active', i === target));
    });
  });
</script>
