---
import Base from '../layouts/Base.astro';
import { socials, type Social } from '../data/socials';
import { xProfiles } from '../data/xProfiles';
import { igProfiles } from '../data/igProfiles';
import { siteKeywords } from '../data/seo';

// Manually-added Instagram entries (socials.ts) + the bulk-imported
// sheet (igProfiles.ts, regenerated by scripts/import-instagram-csv.mjs)
// — both shown together, nothing gets lost either way.
const insta: Social[] = [
  ...socials.filter((s) => s.platform === 'instagram'),
  ...igProfiles.map((p) => ({ platform: 'instagram' as const, handle: p.handle, name: p.name })),
];

function igUrl(s: Social) {
  return `https://instagram.com/${s.handle}`;
}
function label(s: Social) {
  return s.name ?? s.handle;
}
function initial(s: Social) {
  return label(s).charAt(0).toUpperCase();
}

// Group X profiles by location, sorted A-Z. Each becomes its own
// sub-section with a heading, so cities don't blur together.
const byLocation = new Map<string, typeof xProfiles>();
for (const p of xProfiles) {
  const list = byLocation.get(p.location) ?? [];
  list.push(p);
  byLocation.set(p.location, list);
}

// Islamabad, then Lahore, then Karachi — always in that order.
// Anything else found in the data falls after, alphabetically.
const priorityOrder = ['islamabad', 'lahore', 'karachi'];
const locations = [...byLocation.entries()].sort((a, b) => {
  const ai = priorityOrder.indexOf(a[0].toLowerCase());
  const bi = priorityOrder.indexOf(b[0].toLowerCase());
  const aRank = ai === -1 ? priorityOrder.length : ai;
  const bRank = bi === -1 ? priorityOrder.length : bi;
  if (aRank !== bRank) return aRank - bRank;
  return a[0].localeCompare(b[0]);
});

function formatFollowers(n: number) {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace(/\.0$/, '')}M`;
  if (n >= 1_000) return `${(n / 1_000).toFixed(1).replace(/\.0$/, '')}K`;
  return String(n);
}

const pageKeywords = [...new Set([...locations.map(([loc]) => loc), ...siteKeywords])];
---
<Base
  title="Profiles — Instagram & X"
  description="Follow the performers on Instagram and X."
  keywords={pageKeywords}
>
  <header class="page-head">
    <div class="wrap">
      <h1>Profiles</h1>
      <p>Follow the performers on Instagram and X. Tap a card to open their profile.</p>
    </div>
  </header>
  <div class="garland" aria-hidden="true"></div>

  <main class="wrap">
    <section class="social-section">
      <h2 class="sec-title">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.26.07 1.64.07 4.81s0 3.55-.07 4.81c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.26.06-1.64.07-4.85.07s-3.59 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23C2.2 15.55 2.2 15.17 2.2 12s0-3.55.07-4.81c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.41 2.2 8.8 2.2 12 2.2Zm0 3.32a4.53 4.53 0 1 0 0 9.06 4.53 4.53 0 0 0 0-9.06Zm0 1.95a2.58 2.58 0 1 1 0 5.16 2.58 2.58 0 0 1 0-5.16Zm5.77-2.16a1.06 1.06 0 1 1-2.12 0 1.06 1.06 0 0 1 2.12 0Z"/></svg>
        Instagram <span class="sec-count">{insta.length}</span>
      </h2>
      {insta.length === 0 ? (
        <p class="sec-empty">No Instagram profiles added yet.</p>
      ) : (
        <div class="social-grid">
          {insta.map((s) => (
            <a class="social-card social-card--ig" href={igUrl(s)} target="_blank" rel="noopener noreferrer">
              <span class="avatar avatar--ig">{initial(s)}</span>
              <span class="s-meta">
                <span class="s-name">{label(s)}</span>
                <span class="s-handle">@{s.handle}</span>
              </span>
              <span class="s-cta">View →</span>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- ───────── X PROFILES, grouped by location ─────────
         Sourced from src/data/xProfiles.ts, generated by
         scripts/import-x-csv.mjs. Re-run that script and this
         whole section updates — nothing here to hand-edit. -->
    <section class="social-section">
      <h2 class="sec-title">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3.2l-7 8 8.2 10h-6.4l-5-6.1L8.5 21H5.3l7.4-8.5L4.8 3h6.6l4.5 5.6L17.5 3Zm-1.1 16h1.8L8.2 4.9H6.3L16.4 19Z"/></svg>
        X Profiles <span class="sec-count">{xProfiles.length}</span>
      </h2>

      {xProfiles.length === 0 ? (
        <p class="sec-empty">No X profiles imported yet.</p>
      ) : (
        locations.map(([location, people]) => (
          <div class="loc-group">
            <h3 class="loc-title">{location} <span class="sec-count">{people.length}</span></h3>
            <div class="social-grid">
              {people.map((p) => (
                <a class="x-card" href={p.profileUrl} target="_blank" rel="noopener noreferrer">
                  <span class="x-avatar-wrap">
                    {p.avatarUrl ? (
                      <img
                        class="x-avatar"
                        src={p.avatarUrl}
                        alt=""
                        loading="lazy"
                        referrerpolicy="no-referrer"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='grid';"
                      />
                    ) : null}
                    <span class="x-avatar-fallback" style={p.avatarUrl ? 'display:none' : 'display:grid'}>
                      {p.name.charAt(0).toUpperCase()}
                    </span>
                  </span>

                  <span class="x-meta">
                    <span class="x-name-row">
                      <span class="x-name">{p.name}</span>
                      {p.isBlueVerified && (
                        <svg class="x-verified" viewBox="0 0 22 22" width="15" height="15" aria-label="Verified">
                          <path fill="#1d9bf0" d="M20.396 11c-.018-.646-.215-1.275-.57-1.816-.354-.54-.852-.972-1.438-1.246.223-.607.27-1.264.14-1.897-.131-.634-.437-1.218-.886-1.687-.47-.449-1.053-.755-1.687-.886-.633-.13-1.29-.083-1.897.14-.273-.587-.704-1.086-1.245-1.44S11.647 1.62 11 1.604c-.646.017-1.273.213-1.813.568s-.972.851-1.245 1.44c-.607-.223-1.264-.27-1.897-.14-.634.131-1.218.437-1.687.886-.449.469-.755 1.053-.886 1.687-.13.633-.083 1.29.14 1.897-.587.274-1.085.705-1.439 1.246-.353.541-.55 1.17-.569 1.816.02.646.216 1.275.57 1.816.353.54.852.972 1.438 1.246-.223.607-.27 1.264-.14 1.897.131.634.437 1.217.886 1.687.469.448 1.053.754 1.687.885.633.131 1.29.083 1.897-.14.274.588.705 1.087 1.245 1.44.541.354 1.17.551 1.813.567.647-.016 1.276-.213 1.816-.567.541-.353.972-.852 1.245-1.44.607.223 1.264.27 1.897.14.634-.131 1.217-.437 1.687-.885.448-.47.754-1.053.886-1.687.13-.633.083-1.29-.14-1.897.586-.274 1.084-.705 1.438-1.246.354-.541.551-1.17.569-1.816ZM9.662 14.85l-3.429-3.428 1.293-1.293 2.136 2.136 4.65-4.65 1.293 1.293Z"/>
                        </svg>
                      )}
                    </span>
                    <span class="x-handle">@{p.handle}</span>
                  </span>

                  {p.description && <p class="x-desc">{p.description}</p>}

                  <span class="x-footer">
                    <span class="x-followers">{formatFollowers(p.followers)} followers</span>
                    <span class={p.canDm ? 'x-dm x-dm--open' : 'x-dm x-dm--closed'}>
                      {p.canDm ? 'DMs open' : 'DMs closed'}
                    </span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      )}
    </section>
  </main>
</Base>