---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PerformerCard from '../components/PerformerCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { nameFromId } from '../lib/performerImages';
import { siteKeywords } from '../data/seo';

const performers = await getCollection('performers');

performers.sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  const an = a.data.name ?? nameFromId(a.id);
  const bn = b.data.name ?? nameFromId(b.id);
  return an.localeCompare(bn);
});

// City chips. New text-only cards have no city, so skip them —
// otherwise a blank "undefined" chip shows up in the filter bar.
const cityCounts = new Map<string, number>();
for (const p of performers) {
  if (!p.data.city) continue;
  cityCounts.set(p.data.city, (cityCounts.get(p.data.city) ?? 0) + 1);
}
const cities = [...cityCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));

// Category chips. tags is always an array (schema default []), so the
// new cards' auto-tags slot in here with no extra handling needed.
const tagCounts = new Map<string, number>();
for (const p of performers) {
  for (const t of p.data.tags ?? []) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const categories = [...tagCounts.entries()].sort((a, b) => a[0].localeCompare(b[0]));

const autoKeywords = [...cities.map(([c]) => c), ...categories.map(([t]) => t)];
const pageKeywords = [...new Set([...autoKeywords, ...siteKeywords])];
---
<Base title="Shemales of Pakistan" keywords={pageKeywords}>
  <header class="site-header">
    <div class="wrap">
      <p class="kicker">Party · Dating · Functions · Cam Shows · Meetups · Fun</p>
      <h1>Meet your Dream <span class="accent">Shemale</span></h1>
      <p class="tagline">
        Shemales, Gays, Top Shemales, Bottom Shemales, Rawalpindi, Islamabad, Karachi, Islamabad, Lahore, Gujranwala, Multan, Faisalabad. Every type of Shemales 100% Original Phone numbers. Verified. Shemales Pakistan Phone Numbers. Ladyboys Pakistan Phone Numbers. Trans in Pakistan. Trans Pakistan Phone Numbers
      </p>
    </div>
  </header>
  <div class="garland" aria-hidden="true"></div>

  <div class="ad-responsive-banner wrap">
    <div class="ad-desktop-only"><AdSlot variant="banner-728x90" /></div>
    <div class="ad-mobile-only"><AdSlot variant="banner-320x50" /></div>
  </div>

<div class="search-wrap wrap">
  <input type="search" id="search" class="search-input"
         placeholder="Search by name, city, role, keyword…"
         autocomplete="off" aria-label="Search performers" />
</div>



  <div class="filters" id="listings">
    <nav class="filter-bar" aria-label="Filter by city">
      <div class="wrap filter-row">
        <span class="filter-label">City</span>
        <button class="chip" data-city="all" aria-pressed="true">All <span class="count">{performers.length}</span></button>
        {cities.map(([city, count]) => (
          <button class="chip" data-city={city} aria-pressed="false">{city} <span class="count">{count}</span></button>
        ))}
      </div>
    </nav>

   {categories.length > 0 && (
      <nav class="filter-bar filter-bar--tags" aria-label="Filter by category">
        <div class="wrap filter-row">
          <button class="cat-toggle" id="cat-toggle" aria-expanded="false" aria-controls="cat-chips">
            <span class="filter-label">Category</span>
            <span class="chev" aria-hidden="true">▾</span>
          </button>
          <div class="cat-chips" id="cat-chips" hidden>
            <button class="tagchip" data-tag="all" aria-pressed="true">All</button>
            {categories.map(([tag, count]) => (
              <button class="tagchip" data-tag={tag} aria-pressed="false">
                {tag} <span class="count">{count}</span>
              </button>
            ))}
          </div>
        </div>
      </nav>
    )}
  </div>

  <main class="wrap">
   <div class="grid" id="grid">
      {performers.map((entry) => <PerformerCard entry={entry} />)}
      <div class="ad-grid-item"><AdSlot variant="native" /></div>
      <div class="ad-grid-item"><AdSlot variant="banner-300x250" /></div>
      <div class="ad-grid-item"><AdSlot variant="banner-300x250" /></div>
      <p class="empty" id="empty" hidden>No performers match these filters yet.</p>
    </div>
  </main>

<nav class="pager wrap" id="pager" aria-label="Pagination" hidden>
  <button class="pager-btn" id="prev" type="button">← Prev</button>
  <span class="pager-status" id="pager-status"></span>
  <button class="pager-btn" id="next" type="button">Next →</button>
</nav>



<div class="ad-bottom wrap"><AdSlot variant="banner-300x250" /></div>
  <div id="contact"></div>
</Base>

<script>
  // ─────────────────────────────────────────────────────────────
  //  CONFIG
  // ─────────────────────────────────────────────────────────────
  const PER_PAGE = 12;

  const grid = document.getElementById('grid');
  const empty = document.getElementById('empty');
  const pager = document.getElementById('pager');
  const pagerStatus = document.getElementById('pager-status');
  const prevBtn = document.getElementById('prev');
  const nextBtn = document.getElementById('next');
  const searchInput = document.getElementById('search');

  // ── Shuffle the grid on every page load. Featured cards stay
  //    pinned first, then the rest are shuffled randomly. ──
  (function shuffleGrid() {
    if (!grid) return;
    const adNodes = Array.from(grid.querySelectorAll('.ad-grid-item'));
    const cards = Array.from(grid.querySelectorAll('.card'));
    const featured = cards.filter((c) => c.dataset.featured === 'true');
    const rest = cards.filter((c) => c.dataset.featured !== 'true');

    for (let i = rest.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [rest[i], rest[j]] = [rest[j], rest[i]];
    }

    const ordered = [...featured, ...rest];
    let adIndex = 0;
    ordered.forEach((card, i) => {
      grid.insertBefore(card, empty);
      if ((i + 1) % 6 === 0 && adIndex < adNodes.length) {
        grid.insertBefore(adNodes[adIndex], empty);
        adIndex++;
      }
    });
    for (; adIndex < adNodes.length; adIndex++) {
      grid.insertBefore(adNodes[adIndex], empty);
    }
  })();

  // ─────────────────────────────────────────────────────────────
  //  FILTER + SEARCH + PAGINATION  (one unified pass)
  // ─────────────────────────────────────────────────────────────
  const cityChips = document.querySelectorAll('.chip');
  const tagChips = document.querySelectorAll('.tagchip');
  const cards = Array.from(document.querySelectorAll('.card'));
  const adItems = Array.from(document.querySelectorAll('.ad-grid-item'));

  let activeCity = 'all';
  let activeTag = 'all';
  let query = '';
  let currentPage = 1;

  // A card "passes" if it matches city + tag + search query.
  function passes(card) {
    const cityOk = activeCity === 'all' || card.dataset.city === activeCity;
    const cardTags = (card.dataset.tags ?? '').split('|').filter(Boolean);
    const tagOk = activeTag === 'all' || cardTags.includes(activeTag);
    const searchOk = query === '' || (card.dataset.search ?? '').includes(query);
    return cityOk && tagOk && searchOk;
  }

  function render() {
    // 1. Which cards match the active filters + search?
    const matched = cards.filter(passes);

    // 2. Paginate the matched set.
    const totalPages = Math.max(1, Math.ceil(matched.length / PER_PAGE));
    if (currentPage > totalPages) currentPage = totalPages;
    const start = (currentPage - 1) * PER_PAGE;
    const pageCards = matched.slice(start, start + PER_PAGE);
    const pageSet = new Set(pageCards);

    // 3. Show only this page's cards; hide everything else.
    cards.forEach((card) => {
      card.style.display = pageSet.has(card) ? '' : 'none';
    });

    // 4. Ads: show them only when we're browsing the unfiltered,
    //    first page (so they don't break up filtered/search views).
    const pristine = activeCity === 'all' && activeTag === 'all' && query === '';
    adItems.forEach((ad) => {
      ad.style.display = pristine && currentPage === 1 ? '' : 'none';
    });

    // 5. Empty state.
    if (empty) empty.hidden = matched.length !== 0;

    // 6. Pager UI.
    if (pager) {
      const needsPager = matched.length > PER_PAGE;
      pager.hidden = !needsPager;
      if (needsPager && pagerStatus) {
        pagerStatus.textContent = `Page ${currentPage} of ${totalPages} · ${matched.length} results`;
      }
      if (prevBtn) prevBtn.disabled = currentPage <= 1;
      if (nextBtn) nextBtn.disabled = currentPage >= totalPages;
    }
  }

  // Any filter/search change resets to page 1.
  function resetAndRender() {
    currentPage = 1;
    render();
  }

  cityChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      activeCity = chip.dataset.city ?? 'all';
      cityChips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      resetAndRender();
    });
  });

  tagChips.forEach((chip) => {
    chip.addEventListener('click', () => {
      activeTag = chip.dataset.tag ?? 'all';
      tagChips.forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
      resetAndRender();
    });
  });

  if (searchInput) {
    let debounce;
    searchInput.addEventListener('input', () => {
      clearTimeout(debounce);
      debounce = setTimeout(() => {
        query = searchInput.value.trim().toLowerCase();
        resetAndRender();
      }, 120);
    });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) { currentPage--; render(); window.scrollTo({ top: document.getElementById('listings')?.offsetTop ?? 0, behavior: 'smooth' }); }
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      currentPage++; render(); window.scrollTo({ top: document.getElementById('listings')?.offsetTop ?? 0, behavior: 'smooth' });
    });
  }

  // First paint.
  render();

  // ── Category expand / collapse ──
  const catToggle = document.getElementById('cat-toggle');
  const catChips = document.getElementById('cat-chips');
  if (catToggle && catChips) {
    catToggle.addEventListener('click', () => {
      const open = catChips.hasAttribute('hidden');
      if (open) catChips.removeAttribute('hidden');
      else catChips.setAttribute('hidden', '');
      catToggle.setAttribute('aria-expanded', String(open));
    });
  }

  // ── Phone reveal ──
  document.querySelectorAll('.reveal-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (btn.classList.contains('is-revealed')) return;
      const phone = btn.dataset.phone ?? '';
      const label = btn.querySelector('.reveal-label');
      if (label) label.textContent = phone;
      btn.classList.add('is-revealed');
      btn.style.cursor = 'text';
      btn.addEventListener('click', () => { window.location.href = `tel:${phone.replace(/\s+/g, '')}`; });
    });
  });

  // ── Card gallery thumb swap ──
  document.querySelectorAll('.gallery').forEach((gallery) => {
    const shots = gallery.querySelectorAll('.shot');
    const thumbs = gallery.querySelectorAll('.thumb');
    const counter = gallery.querySelector('.photo-count');
    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const target = Number(thumb.dataset.target);
        shots.forEach((s, i) => s.classList.toggle('is-active', i === target));
        thumbs.forEach((t, i) => t.classList.toggle('is-active', i === target));
        if (counter) counter.textContent = `${target + 1} / ${shots.length}`;
      });
    });
  });
</script>