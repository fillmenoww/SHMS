---
import '../styles/global.css';
interface Props { title?: string; description?: string; keywords?: string[]; }
const {
  title = 'Wedding Performers Directory',
  description = 'Book trans dance performers for weddings and functions across Pakistan.',
  keywords = [],
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
 <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- Open Graph — controls how the page looks when shared on WhatsApp/Facebook/etc. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    </head>
  <body>
    <nav class="topnav">
      <div class="wrap topnav-inner">
        <a class="brand" href="/">Performers<span class="brand-dot">.</span></a>
        <div class="nav-links">
          <a href="/">Directory</a>
          <a href="/profiles">Profiles</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="wrap">
        <p>&copy; {new Date().getFullYear()} — All listings shared with performer consent.</p>
      </div>
    </footer>

    <script>
      import {
        ADS_ENABLED,
        popunderCode,
        socialBarCode,
        POPUNDER_FIRST_DELAY_MS,
        POPUNDER_REPEAT_DELAY_MS,
        SOCIAL_BAR_DELAY_MS,
      } from '../data/ads.config';

      if (ADS_ENABLED) {
        const SESSION_START_KEY = 'adsterra_session_start';
        const LAST_ARMED_KEY = 'adsterra_last_armed';
        const SOCIAL_BAR_KEY = 'adsterra_social_bar_loaded';
        const now = Date.now();

        let sessionStart = Number(sessionStorage.getItem(SESSION_START_KEY));
        if (!sessionStart) {
          sessionStart = now;
          sessionStorage.setItem(SESSION_START_KEY, String(sessionStart));
        }
        let lastArmed = Number(sessionStorage.getItem(LAST_ARMED_KEY)) || 0;

        function injectExecutableHTML(html: string, containerId: string) {
          const old = document.getElementById(containerId);
          if (old) old.remove();
          const holder = document.createElement('div');
          holder.id = containerId;
          holder.style.display = 'none';
          document.body.appendChild(holder);

          const temp = document.createElement('div');
          temp.innerHTML = html;
          Array.from(temp.childNodes).forEach((node) => {
            if (node.nodeType === 1 && (node as Element).tagName === 'SCRIPT') {
              const old = node as HTMLScriptElement;
              const fresh = document.createElement('script');
              for (const attr of Array.from(old.attributes)) {
                fresh.setAttribute(attr.name, attr.value);
              }
              fresh.text = old.textContent || '';
              holder.appendChild(fresh);
            } else {
              holder.appendChild(node);
            }
          });
        }

        function schedulePopunder() {
          if (!popunderCode) return;
          const wait =
            lastArmed === 0
              ? Math.max(POPUNDER_FIRST_DELAY_MS - (now - sessionStart), 0)
              : Math.max(POPUNDER_REPEAT_DELAY_MS - (now - lastArmed), 0);

          setTimeout(() => {
            lastArmed = Date.now();
            sessionStorage.setItem(LAST_ARMED_KEY, String(lastArmed));
            injectExecutableHTML(popunderCode, 'adsterra-popunder-holder');
            setInterval(() => {
              lastArmed = Date.now();
              sessionStorage.setItem(LAST_ARMED_KEY, String(lastArmed));
              injectExecutableHTML(popunderCode, 'adsterra-popunder-holder');
            }, POPUNDER_REPEAT_DELAY_MS);
          }, wait);
        }

        function scheduleSocialBar() {
          if (!socialBarCode) return;
          if (sessionStorage.getItem(SOCIAL_BAR_KEY)) return;
          const wait = Math.max(SOCIAL_BAR_DELAY_MS - (now - sessionStart), 0);
          setTimeout(() => {
            sessionStorage.setItem(SOCIAL_BAR_KEY, '1');
            injectExecutableHTML(socialBarCode, 'adsterra-socialbar-holder');
          }, wait);
        }

        schedulePopunder();
        scheduleSocialBar();
      }
    </script>
  </body>
</html>