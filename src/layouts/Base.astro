---
import '../styles/global.css';
interface Props { title?: string; description?: string; keywords?: string[]; }
const {
  title = 'Wedding Performers Directory',
  description = 'Book trans dance performers for weddings and functions across Pakistan.',
  keywords = [],
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
 <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}

    <!-- Open Graph — controls how the page looks when shared on WhatsApp/Facebook/etc. -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- ADSTERRA — paste your Adsterra <script> tag(s) here. Loads on every page. -->
    <!-- <script type="text/javascript" src="//your-adsterra-code.js"></script> -->
  </head>
  <body>
    <nav class="topnav">
      <div class="wrap topnav-inner">
        <a class="brand" href="/">Performers<span class="brand-dot">.</span></a>
        <div class="nav-links">
          <a href="/">Directory</a>
          <a href="/profiles">Profiles</a>
        </div>
      </div>
    </nav>
    <slot />
    <footer class="site-footer">
      <div class="wrap">
        <p>&copy; {new Date().getFullYear()} — All listings shared with performer consent.</p>
      </div>
    </footer>
  </body>
</html>